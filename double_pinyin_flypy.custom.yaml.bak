# double_pinyin_flypy.custom.yaml
patch:
  # 可选：调整候选词数量
  menu/page_size: 9 
  # 启用 Lua 翻译器（用于 date/time 等动态短语）
  engine/translators/@next: lua_translator
  lua_translator:
    module: rime  # 对应 rime.lua

  # 关键：在此方案中显式添加自定义短语翻译器
  engine/translators/@next: table_translator@custom_phrase

  custom_phrase:
    dictionary: ""
    user_dict: custom_phrase    # 对应 custom_phrase.txt
    enable_completion: false
    enable_sentence: false
    initial_quality: 100000     # 高优先级
